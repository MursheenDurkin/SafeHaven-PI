# SafeHaven Pi — line-ending policy
#
# Force LF on every text file checked in, regardless of the host OS.
# Without this, Windows working copies use CRLF (because of git's
# core.autocrlf=true) and `scp`-ing the working copy directly to the
# Pi triggers `\r: command not found` errors when bash runs it.
#
# With these rules in place, both the repo and the working tree
# stay LF — `scp` and `git pull` both produce a Pi-runnable file.

# Default: auto-detect text vs binary, normalise text to LF.
* text=auto eol=lf

# ── Shell, Python, and other executable source ───────────────
*.sh        text eol=lf
*.bash      text eol=lf
*.py        text eol=lf

# ── Web / dashboard ──────────────────────────────────────────
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.json      text eol=lf

# ── Service / config files (run on Linux only) ───────────────
*.conf      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.service   text eol=lf
*.template  text eol=lf
*.rules     text eol=lf

# ── Documentation ────────────────────────────────────────────
*.md        text eol=lf
*.txt       text eol=lf
LICENSE     text eol=lf

# ── Binary assets — never touch line endings ─────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       text eol=lf
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.tgz       binary
*.gz        binary
